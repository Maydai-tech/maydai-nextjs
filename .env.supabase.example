# Optional local-only override for scripts/supabase-ovh.mjs.
# Copy to .env.supabase if you do not want to reuse deploy/.env.
#
# The default workflow expects an SSH tunnel:
#   ./scripts/supabase-ovh-tunnel.sh start
#
# You can either provide a full percent-encoded Postgres URL:
# SUPABASE_DB_URL=postgresql://supabase_admin:password@127.0.0.1:15432/postgres
#
# Or provide components:
# POSTGRES_USER=supabase_admin
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=postgres
SUPABASE_DB_HOST=127.0.0.1
SUPABASE_DB_PORT=15432
SUPABASE_DB_SSLMODE=disable
