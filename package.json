{
  "name": "maydi-admin-app",
  "version": "0.0.3",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "rm -rf .next && next dev",
    "dev:clean": "rm -rf .next node_modules/.cache && next dev",
    "clean": "bash scripts/clean-cache.sh",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config=tests/jest-e2e.config.js",
    "debug:court-long": "jest debug-court-long.integration.test.ts --verbose",
    "test:e2e:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run test:e2e\"",
    "test:worldmap": "node scripts/test-worldmap-corrections.js",
    "supabase:ovh": "node scripts/supabase-ovh.mjs",
    "supabase:ovh:tunnel": "bash scripts/supabase-ovh-tunnel.sh",
    "supabase:ovh:mcp:tunnel": "bash scripts/supabase-ovh-mcp-tunnel.sh",
    "e2e": "npx kill-port 3000 && playwright test",
    "e2e:ui": "npx kill-port 3000 && playwright test --ui",
    "e2e:headed": "npx kill-port 3000 && playwright test --headed",
    "e2e:debug": "npx kill-port 3000 && playwright test --debug"
  },
  "dependencies": {
    "@next/third-parties": "^15.5.7",
    "@react-pdf/renderer": "^4.3.1",
    "@stripe/stripe-js": "^7.9.0",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.9",
    "@types/d3": "^7.4.3",
    "@types/geojson": "^7946.0.16",
    "@types/topojson-client": "^3.1.5",
    "airtable": "^0.12.2",
    "buffer": "^6.0.3",
    "csv-parse": "^6.1.0",
    "d3": "^7.9.0",
    "d3-geo": "^3.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.2",
    "google-ads-api": "^23.0.0",
    "google-auth-library": "^10.7.0",
    "gray-matter": "^4.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.511.0",
    "next": "^15.5.7",
    "node-mailjet": "^6.0.11",
    "openai": "^5.19.1",
    "process": "^0.11.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-flags-select": "^2.5.0",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-lite-youtube-embed": "^3.5.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "stripe": "^18.5.0",
    "topojson-client": "^3.1.0",
    "zod": "^3.25.76"
  },
  "overrides": {
    "js-yaml": "4.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.1.4",
    "@testing-library/react": "^16.1.0",
    "@types/d3-geo": "^3.1.0",
    "@types/jest": "^29.5.5",
    "@types/leaflet": "^1.9.20",
    "@types/node": "^20",
    "@types/puppeteer": "^5.4.7",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "puppeteer": "^24.11.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.1.1",
    "typescript": "^5",
    "wait-on": "^8.0.3"
  },
  "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
