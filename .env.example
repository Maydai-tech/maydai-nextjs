# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Airtable Configuration (Optional)
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE_ID=your_airtable_base_id

# CookieYes Configuration (Required for cookie banner)
NEXT_PUBLIC_COOKIEYES_ID=your_cookieyes_id

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_ASSISTANT_ID=asst_your_assistant_id

# Mistral AI (génération de description cas d'usage — route /api/mistral/generate-description)
MISTRAL_API_KEY=your_mistral_api_key

# Mailjet Configuration
MAILJET_API_KEY=your_mailjet_api_key_public
MAILJET_SECRET_KEY=your_mailjet_secret_key
# Template invitation lead Google Ads (variables Mailjet : firstName, ctaLink)
MAILJET_LEAD_INVITE_TEMPLATE_ID=7948763

# Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Ads API — conversions hors ligne (GCLID dans leads.click_id)
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_ads_developer_token
GOOGLE_ADS_CLIENT_ID=your_oauth_client_id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_ADS_REFRESH_TOKEN=your_oauth_refresh_token
# ID client Google Ads (10 chiffres, avec ou sans tirets)
GOOGLE_ADS_CUSTOMER_ID=1234567890
# Compte manager (MCC) utilisé pour l’authentification API — 10 chiffres, avec ou sans tirets (souvent distinct du compte client)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# Monitoring admin (optionnel — URLs du serveur prod servant disk.json / email-status.json)
# MONITORING_PROD_DISK_JSON_URL=https://votre-serveur/monitoring/disk.json
# MONITORING_PROD_EMAIL_STATUS_JSON_URL=https://votre-serveur/monitoring/email-status.json